{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "ruby@3.4.8"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "jekyll": [
        "bundle exec jekyll build"
      ],
      "doctor": [
        "bundle exec jekyll doctor"
      ],
      "serve": [
        "bundle exec jekyll serve"
      ],
      "show-bundles": [
        "bundle show --paths"
      ],
      "kommeryoutube": [
        "bundle exec ruby _scripts/kommeryoutube.rb"
      ],
      "kommerblog": [
        "bundle exec ruby _scripts/kommerblog.rb"
      ],
      "benfelixyoutube": [
        "bundle exec ruby _scripts/benfelixyoutube.rb"
      ],
      "finanztip": [
        "bundle exec ruby _scripts/finanztip.rb"
      ],
      "uncomitted": [
        "git status -s|grep \"??\"|cut -d \" \" -f 2|grep ^_posts"
      ],
      "untagged": [
        "bundle exec ruby _scripts/list_posts_without_tags.rb"
      ],
      "top-domains": [
        "rg -o 'http.+' $(git status|grep _posts|cut -f2)|grep http|awk -F \"://\" '{print $2}'|cut -d / -f 1|sort|uniq -c|sort -n"
      ],
      "minima-path": [
        "echo $(bundle show minima)"
      ],
      "gamelist": [
        "rg \"achievement in\" _posts/*achievement*|tr '<' '\\n'|awk -F'achievement in ' '{print $2}'|sort|uniq"
      ]
    }
  }
}
